# FlowSpace production provider setup
#
# Copy these values into your deployment environment. Do not commit real secrets.

# App/runtime
MONGO_URL=mongodb+srv://...
DB_NAME=flowspace
ADMIN_PASSWORD=change-me
PUBLIC_APP_URL=https://flowspace.solutions
FRONTEND_URL=https://flowspace.solutions
CORS_ORIGINS=https://flowspace.solutions

# Frontend
REACT_APP_BACKEND_URL=https://api.flowspace.solutions

# Stripe checkout
STRIPE_SECRET_KEY=sk_live_...

# AI text planning
# Used for the organization strategy, DIY guide, benefits, and search terms.
EMERGENT_LLM_KEY=...

# Replicate image editing
IMAGE_PROVIDER=replicate
REPLICATE_API_TOKEN=r8_...
# Default used by the code if omitted:
# REPLICATE_IMAGE_MODEL=black-forest-labs/flux-kontext-pro

# Runway walkthrough video
VIDEO_PROVIDER=runway
RUNWAY_API_KEY=key_...
# Defaults used by the code if omitted:
# RUNWAY_VIDEO_MODEL=gen4_turbo
# RUNWAY_API_VERSION=2024-11-06
# RUNWAY_VIDEO_DURATION=5

# Email notifications
# SMTP is optional. If omitted, jobs complete and PDFs/videos are still available
# on the results page, but no completion email is sent.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USER=...
SMTP_PASSWORD=...
SMTP_FROM=Ryan at FlowSpace <hello@flowspace.solutions>
